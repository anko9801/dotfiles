#!/bin/bash

# Wait for AeroSpace to be ready (workspace queries depend on it)
while ! aerospace list-workspaces --all &>/dev/null; do
  sleep 0.5
done

source "$CONFIG_DIR/plugins/colors.sh"
source "$CONFIG_DIR/plugins/icon_map.sh"

FONT="JetBrainsMono Nerd Font"
APP_FONT="sketchybar-app-font:Regular:14.0"
SPACE_COLORS=($RED $PEACH $YELLOW $GREEN $TEAL $SAPPHIRE $BLUE $MAUVE $PINK)

# Transparent color variants for graph fills
SKY_TRANSPARENT=$(echo "$SKY" | sed 's/0xff/0x40/')
TEAL_TRANSPARENT=$(echo "$TEAL" | sed 's/0xff/0x40/')

# в”Ђв”Ђ Bar Appearance в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
sketchybar --bar \
  height=34 \
  blur_radius=30 \
  position=top \
  sticky=on \
  margin=0 \
  padding_left=8 \
  padding_right=8 \
  color=$BLACK \
  shadow=on

# в”Ђв”Ђ Defaults в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
sketchybar --default \
  icon.font="$FONT:Bold:13.0" \
  icon.color=$WHITE \
  label.font="$FONT:Semibold:11.0" \
  label.color=$WHITE \
  background.color=$SURFACE \
  background.corner_radius=8 \
  background.height=28 \
  background.border_width=2 \
  padding_left=4 \
  padding_right=4 \
  label.padding_left=4 \
  label.padding_right=6 \
  icon.padding_left=8 \
  icon.padding_right=4

# в”Ђв”Ђ LEFT: Workspace Indicators в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
SIDS=($(aerospace list-workspaces --all))
for i in "${!SIDS[@]}"; do
  sid=${SIDS[$i]}
  color=${SPACE_COLORS[$((i % ${#SPACE_COLORS[@]}))]}

  app_icons=""
  app_names=""
  while IFS= read -r app; do
    [ -z "$app" ] && continue
    icon_map "$app"
    if [ "$icon_result" = ":default:" ]; then
      app_names+="$app "
    else
      app_icons+="$icon_result "
    fi
  done <<< "$(aerospace list-windows --workspace "$sid" --format '%{app-name}' 2>/dev/null | sort -u)"
  # icon = workspace ID + text app names (regular font)
  # label = app-font icons only
  display_icon="$sid"
  [ -n "$app_names" ] && display_icon="$sid $app_names"

  # Hide workspaces with no windows (unless focused)
  focused=$(aerospace list-workspaces --focused 2>/dev/null)
  has_windows=0
  [ -n "$app_icons" ] || [ -n "$app_names" ] && has_windows=1
  show_item=off
  [ "$has_windows" = "1" ] || [ "$sid" = "$focused" ] && show_item=on

  sketchybar --add item space.$sid left \
    --subscribe space.$sid aerospace_workspace_change \
    --set space.$sid \
      drawing=$show_item \
      background.color=$SURFACE \
      background.border_color=$color \
      background.corner_radius=8 \
      background.height=28 \
      background.drawing=off \
      icon="$display_icon" \
      icon.color=$color \
      icon.font="$FONT:Bold:13.0" \
      icon.padding_left=8 \
      icon.padding_right=4 \
      label="$app_icons" \
      label.color=$color \
      label.font="$APP_FONT" \
      update_freq=3 \
      click_script="aerospace workspace $sid" \
      script="$CONFIG_DIR/plugins/aerospace.sh $sid $color"
done

# в”Ђв”Ђ LEFT: Front App в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
sketchybar --add item front_app left \
  --set front_app \
    icon.font="sketchybar-app-font:Regular:16.0" \
    icon.color=$LAVENDER \
    label.font="$FONT:Bold:11.0" \
    label.color=$LAVENDER \
    background.drawing=off \
    script="$CONFIG_DIR/plugins/front_app.sh" \
  --subscribe front_app front_app_switched

# в”Ђв”Ђ RIGHT: Calendar (bracket) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
sketchybar --add item clock right \
  --set clock \
    icon.drawing=off \
    label.font="$FONT:Bold:12.0" \
    label.color=$BLUE \
    background.drawing=off \
    update_freq=10 \
    script="$CONFIG_DIR/plugins/clock.sh" \
  --subscribe clock system_woke

sketchybar --add item date right \
  --set date \
    icon.drawing=off \
    label.font="$FONT:Semibold:10.0" \
    label.color=$BLUE \
    background.drawing=off \
    update_freq=60 \
    script="$CONFIG_DIR/plugins/date.sh" \
  --subscribe date system_woke

sketchybar --add bracket cal clock date \
  --set cal \
    background.color=$SURFACE \
    background.corner_radius=8 \
    background.height=28 \
    background.border_color=$BLUE \
    background.border_width=2

# в”Ђв”Ђ RIGHT: Media в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
sketchybar --add item media right \
