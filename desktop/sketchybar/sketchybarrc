sketchybar --add item media.playpause popup.media \
  --set media.playpause \
    icon="у°ђЋ" \
    icon.color=$PINK \
    icon.padding_left=8 \
    icon.padding_right=8 \
    label.drawing=off \
    background.drawing=off \
    click_script="nowplaying-cli togglePlayPause 2>/dev/null"

sketchybar --add item media.next popup.media \
  --set media.next \
    icon="у°’­" \
    icon.color=$PINK \
    icon.padding_left=8 \
    icon.padding_right=8 \
    label.drawing=off \
    background.drawing=off \
    click_script="nowplaying-cli next 2>/dev/null"

# в”Ђв”Ђ RIGHT: Battery (bracket + popup) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
sketchybar --add item battery right \
